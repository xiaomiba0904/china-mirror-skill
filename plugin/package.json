{
  "name": "@xiaomiba0904/openclaw-china-mirror",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenClaw plugin for China mirror source detection and configuration hints",
  "author": "xiaomiba0904",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaomiba0904/china-mirror-skill"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "mirror",
    "china",
    "npm",
    "pip",
    "cargo"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "../SKILL.md",
    "../scripts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}